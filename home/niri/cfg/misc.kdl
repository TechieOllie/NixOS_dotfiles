    prefer-no-csd
    screenshot-path null

    environment {
        ELECTRON_OZONE_PLATFORM_HINT "auto"
        QT_QPA_PLATFORM "wayland"
        QT_QPA_PLATFORMTHEME "qt6ct"
        QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
        XDG_CURRENT_DESKTOP "niri"
        XDG_SESSION_TYPE "wayland"
    }

    debug {
        // Allows notification actions and window activation from Noctalia.
        honor-xdg-activation-with-invalid-serial
    }

    hotkey-overlay {
       skip-at-startup
    }

    cursor {
       xcursor-theme "Bibata-Modern-Classic"
       xcursor-size 22
    }

    clipboard {
    disable-primary
    }

    // Global blur tuning (Noctalia v5 compositor-settings docs), paired
    // with the per-surface blur/xray window-rule and layer-rules in
    // rules.kdl. Requires niri 26.04+ (this repo's pinned nixpkgs ships
    // exactly that version).
    blur {
        passes 2
        offset 3.0
        noise 0.03
        saturation 1.0
    }

    // Command updated to Noctalia's current recommendation
    // (noctalia msg session lock-and-suspend, replacing the old plain
    // systemctl suspend-then-hibernate) — still commented out, since no
    // bootstrapped host has a lid switch yet (VM only; the laptop isn't
    // installed). Also needs services.logind's HandleLidSwitch=ignore at
    // the system level once a real laptop host enables this, so niri
    // itself handles the lid event instead of systemd — revisit then.
    //switch-events {
       //lid-close { spawn "noctalia" "msg" "session" "lock-and-suspend"; }
    //}
