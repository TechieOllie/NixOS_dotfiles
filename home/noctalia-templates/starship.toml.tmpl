"$schema" = 'https://starship.rs/config-schema.json'

format = '''
[┌─ ](bold {{colors.primary.default.hex}})$username$directory $git_branch$python
[└─$character ]({{colors.primary.default.hex}} bold) '''

[git_branch]
format = '[$symbol$branch(:$remote_branch) ]($style)'

[python]
format = '[via ${symbol} (\($virtualenv\)) ]($style)'
symbol = ''

[character]
disabled = false

[username]
show_always = true

[directory]
format = "[$path]({{colors.secondary.default.hex}} bold)"
truncation_length = 8
truncation_symbol = '…/'
